@model ProjetoGS.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Login - Projeto GS</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --fiap-pink: #ed145b;
            --fiap-dark: #0d0d0d;
            --fiap-gray: #1c1c1c;
            --fiap-light: #f5f5f5;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(237, 20, 91, 0.35), transparent 35%), linear-gradient(135deg, #050505 0%, #151515 55%, #250014 100%);
            color: var(--fiap-light);
            display: flex;
            align-items: center;
        }

        .login-wrapper {
            width: 100%;
        }

        .brand-box {
            color: white;
        }

        .brand-badge {
            display: inline-block;
            padding: 6px 14px;
            border: 1px solid var(--fiap-pink);
            color: var(--fiap-pink);
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

        .brand-title {
            font-size: 3rem;
            font-weight: 800;
            line-height: 1.05;
        }

            .brand-title span {
                color: var(--fiap-pink);
            }

        .brand-text {
            color: #cfcfcf;
            max-width: 520px;
            margin-top: 18px;
            font-size: 1.05rem;
        }

        .login-card {
            background: rgba(20, 20, 20, 0.92);
            border: 1px solid rgba(237, 20, 91, 0.35);
            border-radius: 22px;
            box-shadow: 0 25px 70px rgba(0, 0, 0, 0.55);
            overflow: hidden;
        }

        .login-card-header {
            background: linear-gradient(90deg, var(--fiap-pink), #8b0031);
            padding: 28px;
            text-align: center;
        }

            .login-card-header h3 {
                margin: 0;
                font-weight: 800;
                color: white;
            }

            .login-card-header small {
                color: rgba(255, 255, 255, 0.85);
            }

        .login-card-body {
            padding: 32px;
        }

        .form-label {
            color: #e6e6e6;
            font-weight: 600;
        }

        .form-control {
            background-color: #101010;
            border: 1px solid #333;
            color: white;
            border-radius: 12px;
            padding: 12px 14px;
        }

            .form-control:focus {
                background-color: #101010;
                color: white;
                border-color: var(--fiap-pink);
                box-shadow: 0 0 0 0.2rem rgba(237, 20, 91, 0.2);
            }

        .btn-fiap {
            background: var(--fiap-pink);
            border: none;
            color: white;
            font-weight: 700;
            border-radius: 12px;
            padding: 12px;
            transition: 0.2s;
        }

            .btn-fiap:hover {
                background: #c90f4c;
                color: white;
                transform: translateY(-1px);
            }

        .login-footer {
            color: #aaa;
            font-size: 0.85rem;
            text-align: center;
            margin-top: 18px;
        }

        @@media (max-width: 767px) {
            .brand-box {
                text-align: center;
                margin-bottom: 32px;
            }

            .brand-title {
                font-size: 2.2rem;
            }
        }
    </style>
</head>

<body>
    <div class="login-wrapper">
        <div class="container">
            <div class="row align-items-center justify-content-center">

                <div class="col-lg-6 mb-4 mb-lg-0">
                    <div class="brand-box">
                        <div class="brand-badge">FIAP • Global Solution</div>

                        <h1 class="brand-title">
                            Nova Economia <span>Espacial</span>
                        </h1>

                        <p class="brand-text">
                            Plataforma para catalogar, monitorar e analisar tecnologias
                            derivadas da exploração espacial e seus impactos na sociedade.
                        </p>
                    </div>
                </div>

                <div class="col-lg-5 col-md-7">
                    <div class="login-card">

                        <div class="login-card-header">
                            <h3>Projeto GS</h3>
                            <small>Acesse o painel administrativo</small>
                        </div>

                        <div class="login-card-body">

                            @if (ViewBag.Erro != null)
                            {
                                <div class="alert alert-danger">
                                    @ViewBag.Erro
                                </div>
                            }

                            <form asp-action="Login" method="post">

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">
                                        E-mail
                                    </label>
                                    <input asp-for="Email"
                                           class="form-control"
                                           placeholder="admin@fiap.com" />
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Senha" class="form-label">
                                        Senha
                                    </label>
                                    <input asp-for="Senha"
                                           type="password"
                                           class="form-control"
                                           placeholder="Digite sua senha" />
                                </div>

                                <button type="submit"
                                        class="btn btn-fiap w-100">
                                    Entrar
                                </button>

                            </form>

                            <div class="login-footer">
                                Sistema acadêmico desenvolvido em ASP.NET Core MVC
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>