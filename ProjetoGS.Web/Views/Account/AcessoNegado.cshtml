@{
    ViewData["Title"] = "Acesso Negado";
}

<style>

    .access-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .access-card {
        width: 100%;
        max-width: 700px;
        background: radial-gradient(circle at top right, rgba(237,20,91,.25), transparent 30%), linear-gradient(135deg,#050505,#151515,#250011);
        border: 1px solid rgba(237,20,91,.25);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,.35);
    }

    .access-header {
        padding: 30px;
        text-align: center;
        border-bottom: 1px solid rgba(237,20,91,.15);
    }

    .access-icon {
        font-size: 4rem;
        margin-bottom: 15px;
    }

    .access-title {
        color: white;
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 10px;
    }

        .access-title span {
            color: #ed145b;
        }

    .access-body {
        padding: 35px;
        text-align: center;
    }

    .access-message {
        color: #c7c7c7;
        font-size: 1.1rem;
        margin-bottom: 30px;
    }

    .access-box {
        background: rgba(237,20,91,.08);
        border: 1px solid rgba(237,20,91,.25);
        border-radius: 16px;
        padding: 20px;
        color: #ff8ab3;
        margin-bottom: 30px;
    }

    .btn-fiap {
        background: #ed145b;
        border: none;
        color: white;
        font-weight: 700;
        border-radius: 12px;
        padding: 12px 22px;
    }

        .btn-fiap:hover {
            background: #c90f4c;
            color: white;
        }

</style>

<div class="access-container">

    <div class="access-card">

        <div class="access-header">

            <div class="access-icon">
                🔒
            </div>

            <h1 class="access-title">
                Acesso <span>Negado</span>
            </h1>

        </div>

        <div class="access-body">

            <p class="access-message">
                Você não possui permissão para acessar esta funcionalidade.
            </p>

            <div class="access-box">
                Seu perfil possui acesso restrito a determinadas operações do sistema.
                Caso precise desta funcionalidade, solicite acesso a um administrador.
            </div>

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-fiap">
                Voltar ao Dashboard
            </a>

        </div>

    </div>

</div>
