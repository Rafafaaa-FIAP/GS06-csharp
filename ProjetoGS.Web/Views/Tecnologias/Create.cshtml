@model ProjetoGS.Web.Models.CreateTecnologiaViewModel

@{
    ViewData["Title"] = "Nova Tecnologia";
}

<div class="container mt-4">

    <h2>Nova Tecnologia</h2>

    <form method="post">

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Descricao" class="form-label"></label>
            <textarea asp-for="Descricao"
                      class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="MissaoOrigem"
                   class="form-label"></label>

            <input asp-for="MissaoOrigem"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="CategoriaImpactoId"
                   class="form-label"></label>

            <select asp-for="CategoriaImpactoId"
                    asp-items="Model.Categorias"
                    class="form-select">

                <option value="">
                    Selecione...
                </option>

            </select>
        </div>

        <button type="submit"
                class="btn btn-success">
            Salvar
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Voltar
        </a>

    </form>

</div>