@model ErrorViewModel

@{
    ViewData["Title"] = "Erro";
}

<div class="container py-5">

    ```
    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-header text-white"
                     style="background: linear-gradient(90deg, #ed145b, #9c003a);">

                    <h2 class="mb-0">
                        ⚠️ Ocorreu um erro
                    </h2>

                </div>

                <div class="card-body p-4">

                    <h4 class="mb-3">
                        Não foi possível concluir a operação solicitada.
                    </h4>

                    <p class="text-muted">
                        O sistema encontrou uma situação inesperada durante o processamento da sua solicitação.
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="alert alert-secondary mt-4">
                            <strong>ID da Requisição:</strong>
                            <code>@Model.RequestId</code>
                        </div>
                    }

                    <div class="mt-4">

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-primary">
                            Voltar ao Dashboard
                        </a>

                        <a href="javascript:history.back();"
                           class="btn btn-outline-secondary">
                            Página Anterior
                        </a>

                    </div>

                </div>

                <div class="card-footer bg-light text-muted">

                    Projeto GS • Nova Economia Espacial • FIAP

                </div>

            </div>

        </div>

    </div>
    ```

</div>
