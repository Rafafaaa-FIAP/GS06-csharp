@using System.Security.Claims

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Projeto GS</title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/ProjetoGS.Web.styles.css"
          asp-append-version="true" />

    <style>
        :root {
            --fiap-pink: #ed145b;
            --fiap-dark: #070707;
            --fiap-card: #151515;
            --fiap-border: #2a2a2a;
        }

        html {
            background: var(--fiap-dark);
        }

        body {
            background: var(--fiap-dark);
            color: #f5f5f5;
            min-height: 100vh;
        }

        .navbar-fiap {
            background: linear-gradient(90deg,#000,#111,#250011);
            border-bottom: 2px solid var(--fiap-pink);
        }

        .navbar-brand {
            color: white !important;
            font-weight: 900;
        }

            .navbar-brand span {
                color: var(--fiap-pink);
            }

        .nav-link {
            color: rgba(255,255,255,.85) !important;
            font-weight: 600;
        }

            .nav-link:hover {
                color: white !important;
            }

        .user-chip {
            border: 1px solid rgba(237,20,91,.3);
            background: rgba(237,20,91,.08);
            color: white;
            border-radius: 999px;
            padding: 6px 14px;
        }

        .btn-logout {
            border: 1px solid var(--fiap-pink);
            border-radius: 999px;
            color: white;
            text-decoration: none;
            padding: 6px 14px;
        }

            .btn-logout:hover {
                background: var(--fiap-pink);
                color: white;
            }

        main {
            padding-top: 25px;
        }

        .footer-fiap {
            border-top: 1px solid var(--fiap-border);
            background: #111;
            color: #aaa;
            padding: 18px 0;
            margin-top: 40px;
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-fiap shadow-sm">
            <div class="container-fluid px-4">

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">
                    FIAP <span>SpaceTech</span>
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse"
                     id="mainNavbar">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto ms-3">
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Tecnologias"
                                   asp-action="Index">
                                    Tecnologias
                                </a>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Tecnologias"
                                       asp-action="Create">
                                        Nova Tecnologia
                                    </a>
                                </li>
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0">
                            <div class="user-chip">
                                <strong>@User.Identity.Name</strong>
                                <span class="text-white-50">
                                    (@User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value)
                                </span>
                            </div>

                            <a class="btn-logout"
                               asp-controller="Account"
                               asp-action="Logout">
                                Sair
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-fiap">
        <div class="container-fluid px-4 d-flex justify-content-between">
            <span>&copy; 2026 - Projeto GS</span>
            <span>Nova Economia Espacial • FIAP</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>